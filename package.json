{
  "name": "cloudflare-workers",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:assets": "turbo run build --filter=assets",
    "build:image": "turbo run build --filter=image",
    "build:models": "turbo run build --filter=models",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "dev:all": "turbo run dev --parallel",
    "dev:assets": "turbo run dev --filter=assets",
    "dev:image": "turbo run dev --filter=image",
    "dev:models": "turbo run dev --filter=models",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "turbo run typecheck",
    "cf-typegen": "turbo run cf-typegen"
  },
  "devDependencies": {
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev",
    "turbo": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev",
    "wrangler": "catalog:dev"
  },
  "packageManager": "pnpm@11.5.0"
}
