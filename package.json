{
  "name": "cloudflare-workers",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:assets": "pnpm --filter assets build",
    "build:image": "pnpm --filter image build",
    "test": "pnpm vitest --run",
    "test:watch": "pnpm vitest",
    "dev:all": "pnpm -r dev",
    "dev:assets": "pnpm --filter assets dev",
    "dev:image": "pnpm --filter image dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "pnpm -r typecheck",
    "cf-typegen": "pnpm -r cf-typegen"
  },
  "devDependencies": {
    "typescript": "catalog:dev",
    "vitest": "catalog:dev",
    "wrangler": "catalog:dev",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev"
  }
}
